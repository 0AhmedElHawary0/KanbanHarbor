                                    "let jsonData = {};",
                                    "try { jsonData = pm.response.json(); } catch (e) {}",
                                    "const tenantId = jsonData?.data?.id || null;",
                                    "if (tenantId) {",
                                    "  pm.environment.set('tenant_id', tenantId);",
                                    "}"
                                ]
                            }
