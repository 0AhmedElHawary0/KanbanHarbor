                        "description": "List members for current tenant. Requires permission member.view."
                    }
                },
                {
                    "name": "Update Tenant Member Role",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "X-Tenant-Id",
                                "value": "{{tenant_id}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"admin\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/tenants/{{tenant_id}}/members/{{user_id}}/role",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "tenants",
                                "{{tenant_id}}",
                                "members",
                                "{{user_id}}",
                                "role"
                            ]
                        },
                        "description": "Update a member role. Requires permission member.role.update."
                    }
                }
            ]
        },
